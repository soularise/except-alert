# Database
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# Auth (generate a random secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# Admin
EXCEPTALERT_ADMIN_EMAILS=you@example.com
EXCEPTALERT_APP_URL=http://localhost:3000

# Relay (default works with Docker Compose)
RELAY_URL=http://relay:3800

# Optional: password reset event routing
EXCEPTALERT_PASSWORD_RESET_EVENT_TENANT_ID=
EXCEPTALERT_PASSWORD_RESET_EVENT_TENANT_SLUG=
